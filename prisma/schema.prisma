generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Invoice {
  id String @id @default(cuid())
  number String @unique
  client String
  amount Float
  status String @default("draft")
  issuedAt DateTime @default(now())
  dueAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
}

model Product{
  id String @id @default(cuid())
  name String
  sku String @unique
  category String
  stock Int @default(0)
  price Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}